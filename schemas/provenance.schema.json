{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MESSINA Public Provenance Record",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "source_type": {"type": "string"},
    "source_reference": {"type": "string"},
    "rationale": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "status": {
      "type": "string",
      "enum": ["calibrated", "estimated", "stylized", "provisional", "placeholder"]
    },
    "notes": {"type": "string"}
  },
  "required": ["source_type", "source_reference", "rationale", "confidence", "status"]
}
